{
  "name": "@pickme/reminder",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "workspaces": [
    "api",
    "worker"
  ],
  "scripts": {
    "build:api": "npm run build -workspace api",
    "build:worker": "npm run build -workspace worker",
    "build": "npm run build:api && npm run build:worker",
    "start:api": "dotenv -e .env -- npm run start -workspace api",
    "start:worker": "dotenv -e .env -- npm run start -workspace worker",
    "start": "concurrently \"npm run start:api\" \"npm run start:worker\"",
    "format": "npm run format -workspace api && npm run format -workspace worker",
    "lint": "npm run lint -workspace api && npm run lint -workspace worker",
    "docs": "typedoc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "generate-openapi": "npm run generate-openapi -workspace api"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "ioredis": "^5.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.3.0",
    "jest-html-reporters": "^3.1.7",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2"
  }
}
