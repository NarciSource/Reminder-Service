{
  "files": [],
  "include": ["../api/src/**/*.ts", "../worker/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"],

  "compilerOptions": {
    "experimentalDecorators": true, // 데코레이터 기능 활성화
    "emitDecoratorMetadata": true, // 데코레이터 메타데이터를 생성
    "paths": {
      "@api/*": ["./api/src/*"],
      "@worker/*": ["./worker/src/*"]
    }
  },

  "references": [
    {
      "path": "api"
    },
    {
      "path": "worker"
    }
  ]
}
